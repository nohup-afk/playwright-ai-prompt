# ─── Application under test ──────────────────────────────────────────────
# Base URL the tests and agent target.
BASE_URL=https://www.saucedemo.com

# Test credentials (kept out of committed specs).
TEST_USERNAME=standard_user
TEST_PASSWORD=secret_sauce

# ─── LLM provider ────────────────────────────────────────────────────────
# llamacpp | claude-cli | ollama | anthropic | openai  (default: llamacpp)
PWAI_PROVIDER=llamacpp

# claude-cli: uses the Claude Code CLI with your claude.ai login — NO API key.
#   npm install -g @anthropic-ai/claude-code   (then run `claude` once to log in)
# PWAI_PROVIDER=claude-cli
# PWAI_MODEL=sonnet            # sonnet | opus | haiku
# CLAUDE_CLI_PATH=claude       # override if claude isn't on PATH

# llama.cpp (llama-server, OpenAI-compatible API)
# Start with e.g.: llama-server -hf Qwen/Qwen2.5-Coder-7B-Instruct-GGUF:Q4_K_M -c 16384 --port 8080
LLAMACPP_BASE_URL=http://localhost:8080
# LLAMACPP_API_KEY=          # only if llama-server runs with --api-key

# Model override (llamacpp uses whatever the server loaded; informational)
# PWAI_MODEL=qwen2.5-coder

# Ollama
# OLLAMA_BASE_URL=http://localhost:11434

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# LLM timeout in ms. Codegen/self-heal default: 120000. Agent planner default: 300000.
# Raise this if llama.cpp times out on large prompts (slow CPU/iGPU).
# PWAI_TIMEOUT=600000

# Force regeneration of all cached steps (like cy.ai regenerate: true)
# PWAI_REGENERATE=1

# Disable command logging
# PWAI_LOG=0
